---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Y. Jemlaoui', description = 'Security research, detection engineering, and threat hunting.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <nav>
    <a class="nav-logo" href="/">Y. Jemlaoui</a>
    <ul class="nav-links">
      <li><a href="/">Writing</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="https://github.com/glikoaop0" target="_blank" rel="noopener">GitHub ↗</a></li>
      <li><a href="/experience">Experience</a></li>
    </ul>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <span>© {new Date().getFullYear()} Yassine Jemlaoui</span>
    <div class="footer-links">
      <a href="https://x.com/yassineikopa" target="_blank" rel="noopener">Twitter</a>
      <a href="https://www.linkedin.com/in/yassine-jemlaouisec/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://github.com/" target="_blank" rel="noopener">GitHub</a>
    </div>
  </footer>

</body>
</html>
