---
import Base from '../layouts/Base.astro';
---

<Base title="Experience — Y. Jemlaoui">
  <div class="exp-page">

    <div class="page-header">
      <div class="page-tag">Experience</div>
      <h1>Background</h1>
      <p class="page-sub">Blue team · Threat hunting · Cloud security</p>
    </div>

    <section class="section">
      <div class="section-label">Journey</div>
      <div class="timeline">

        <div class="timeline-item current">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div>
                <div class="role">SOC Analyst & Threat Hunter</div>
                <div class="company">i-Tracing — Paris</div>
              </div>
              <div class="period">Sept 2025 → Present</div>
            </div>
            <p class="timeline-desc">
              Proactive threat hunting across endpoint and cloud environments in a multi-client MSSP context.
              Detection engineering on CI/CD abuse patterns, supply chain campaigns, and Active Directory
              persistence techniques. Focus on cloud security; GCP, AWS, and Azure
              hunting initiatives
            </p>
            <div class="tags">
              <span class="tag">SIEM</span>
              <span class="tag">EDR</span>
              <span class="tag">Multi cloud solution</span>
              <span class="tag">SOAR</span>
              <span class="tag">GCP · AWS · Azure</span>
              <span class="tag">Threat hunting</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div>
                <div class="role">SOC Analyst — Intern</div>
                <div class="company">i-Tracing — Paris</div>
              </div>
              <div class="period">Sept 2024 → Sept 2025</div>
            </div>
            <p class="timeline-desc">
              Alert triage and in-depth investigation across multiple client environments.
              Conducted CVE research and threat intelligence analysis.
              Assisted during critical incidents and crisis response situations.
            </p>
           
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div>
                <div class="role">Data Scientist — Intern</div>
                <div class="company">Research Department · University — Morocco</div>
              </div>
              <div class="period">Apr 2023 → Jul 2023</div>
            </div>
            <p class="timeline-desc">
              Built an end-to-end ML pipeline on a 10,000-record medical dataset.
              Developed and compared predictive models (SVM, Decision Tree, MLP)
              optimised via cross-validation and grid search.
            </p>
            <div class="tags">
              <span class="tag">Python</span>
              <span class="tag">Scikit-learn</span>
              <span class="tag">Machine learning</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div>
                <div class="role">Full-stack Developer — Intern</div>
                <div class="company">Ministry of the Interior — Morocco</div>
              </div>
              <div class="period">Apr 2022 → Jun 2022</div>
            </div>
            <p class="timeline-desc">
              Designed and developed a full-stack web application using Java Spring Boot
              and React. Implemented RESTful API and MySQL database integration.
            </p>
            <div class="tags">
              <span class="tag">Java Spring Boot</span>
              <span class="tag">React</span>
              <span class="tag">MySQL</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <section class="section">
      <div class="section-label">Stack & skills</div>
      <div class="skills-grid">

        <div class="skill-group">
          <div class="skill-group-title">Detection & Response</div>
          <div class="skill-items">
            <span class="skill">Splunk SPL</span>
            <span class="skill">Sigma rules</span>
            <span class="skill">XSOAR playbooks</span>
            <span class="skill">Incident response</span>
            <span class="skill">Threat hunting</span>
          </div>
        </div>

        <div class="skill-group">
          <div class="skill-group-title">Cloud Security</div>
          <div class="skill-items">
            <span class="skill">GCP</span>
            <span class="skill">AWS</span>
            <span class="skill">Azure</span>
            <span class="skill">Wiz (CSPM)</span>
            <span class="skill">Cloud audit logs</span>
          </div>
        </div>

        <div class="skill-group">
          <div class="skill-group-title">Endpoint & Identity</div>
          <div class="skill-items">
            <span class="skill">SentinelOne</span>
            <span class="skill">Active Directory</span>
            <span class="skill">Entra ID</span>
            <span class="skill">macOS security</span>
          </div>
        </div>

        <div class="skill-group">
          <div class="skill-group-title">Malware & Research</div>
          <div class="skill-items">
            <span class="skill">Malware analysis</span>
            <span class="skill">Ghidra</span>
            <span class="skill">CI/CD security</span>
            <span class="skill">Supply chain attacks</span>
          </div>
        </div>

      </div>
    </section>

    <section class="section">
      <div class="section-label">Education & certifications</div>
      <div class="edu-grid">

        <div class="edu-col">
          <div class="edu-col-title">Certifications</div>
          <div class="edu-item">
            <div class="edu-status pursuing">In progress</div>
            <div class="edu-name">AWS Security Specialty</div>
            <div class="edu-org">Amazon Web Services</div>
          </div>
        </div>
 <div class="edu-col-title">Certifications</div>
          <div class="edu-item">
            <div class="edu-status pursuing">In progress</div>
            <div class="edu-name">Wiz Defend Certification </div>
            <div class="edu-org">WIZ</div>
          </div>
        </div>

        <div class="edu-col">
          <div class="edu-col-title">Education</div>
          <div class="edu-item">
            <div class="edu-name">Master's — Computer Science, Cybersecurity</div>
            <div class="edu-org">Université Paris Cité &nbsp;·&nbsp; 2023 – 2025</div>
          </div>
        </div>

      </div>
    </section>

  </div>
</Base>

<style>
  .exp-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 5rem 2rem 8rem;
    animation: fadeUp 0.7s 0.05s ease both;
  }

  .page-header { margin-bottom: 4rem; }

  .page-tag {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .page-tag::before {
    content: '';
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--accent);
  }

  h1 {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 400;
    margin-bottom: 0.5rem;
  }

  .page-sub {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--cream-dim);
    letter-spacing: 0.08em;
  }

  .section { margin-bottom: 4rem; }

  .section-label {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cream-dim);
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    position: relative;
    padding-left: 1.5rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 8px;
    bottom: 0;
    width: 1px;
    background: var(--border);
  }

  .timeline-item {
    position: relative;
    padding-bottom: 2.5rem;
  }

  .timeline-item:last-child { padding-bottom: 0; }

  .timeline-dot {
    position: absolute;
    left: -1.5rem;
    top: 6px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--bg);
    border: 1.5px solid var(--cream-dim);
  }

  .timeline-item.current .timeline-dot {
    background: var(--accent);
    border-color: var(--accent);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .role {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--cream);
    margin-bottom: 0.2rem;
  }

  .company {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 0.06em;
  }

  .period {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--cream-dim);
    white-space: nowrap;
    padding-top: 0.15rem;
  }

  .timeline-desc {
    font-size: 0.92rem;
    color: var(--cream-dim);
    line-height: 1.75;
    margin-bottom: 1rem;
    max-width: 580px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    color: var(--accent-dim);
    border: 1px solid var(--accent-dim);
    padding: 0.15rem 0.55rem;
    border-radius: 2px;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 2.5rem;
  }

  .skill-group-title {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream-dim);
    margin-bottom: 0.75rem;
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--cream);
    background: var(--bg-2);
    border: 1px solid var(--border);
    padding: 0.25rem 0.65rem;
    border-radius: 2px;
    letter-spacing: 0.03em;
  }

  .edu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .edu-col-title {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream-dim);
    margin-bottom: 1.25rem;
  }

  .edu-item {
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .edu-item:first-of-type { border-top: 1px solid var(--border); }

  .edu-status {
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.12rem 0.5rem;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 0.4rem;
  }

  .edu-status.pursuing {
    color: var(--accent);
    border: 1px solid var(--accent-dim);
  }

  .edu-status.obtained {
    color: #6a9f6a;
    border: 1px solid #3a5f3a;
  }

  .edu-name {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--cream);
    margin-bottom: 0.2rem;
  }

  .edu-org {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--cream-dim);
    letter-spacing: 0.04em;
  }

  @media (max-width: 600px) {
    .exp-page { padding: 3rem 1.5rem 5rem; }
    .skills-grid { grid-template-columns: 1fr; }
    .edu-grid { grid-template-columns: 1fr; }
    .timeline-header { flex-direction: column; gap: 0.3rem; }
  }
</style>
