---
import Base from '../layouts/Base.astro';

// Grab all markdown articles, sorted by date desc
const articleFiles = import.meta.glob('./articles/*.md', { eager: true });
const articles = Object.values(articleFiles)
  .filter(a => !a.frontmatter.draft)
---

<Base>
  <div class="hero">
    <div class="hero-tag">SOC Analyst · Threat Hunter · Paris</div>
    <h1>Hunting threats,<br /><em>building detections,</em><br />and field notes.</h1>
    <p>Writeups, threat hunting research, and technical articles from the trenches of blue team work.</p>
  </div>


  <div class="section-divider">
    <span>Latest writing</span>
  </div>

  <div class="articles">
    {articles.map((article) => {
      const date = new Date(article.frontmatter.date).toISOString().split('T')[0];
      const tags = article.frontmatter.tags ?? [];
      return (
        <a class="article-item" href={article.url}>
          <div class="article-meta">
            <span class="article-date">{date}</span>
            {tags[0] && <span class="article-tag">{tags[0]}</span>}
          </div>
          <div class="article-body">
            <div class="article-title">{article.frontmatter.title}</div>
            {article.frontmatter.excerpt && (
              <div class="article-excerpt">{article.frontmatter.excerpt}</div>
            )}
          </div>
          <div class="article-arrow">→</div>
        </a>
      );
    })}
  </div>
</Base>

<style>
  .hero {
    padding: 6rem 4rem 5rem;
    max-width: 860px;
    animation: fadeUp 0.7s 0.1s ease both;
  }

  .hero-tag {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.8rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .hero-tag::before {
    content: '';
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--accent);
  }

  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--cream);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--cream-dim);
  }

  .hero p {
    font-size: 1.05rem;
    color: var(--cream-dim);
    max-width: 520px;
    line-height: 1.75;
  }

  .section-divider {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0 4rem;
    margin-bottom: 0;
    animation: fadeUp 0.7s 0.2s ease both;
  }

  .section-divider span {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cream-dim);
    white-space: nowrap;
  }

  .section-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .articles {
    padding: 0 4rem 6rem;
    display: flex;
    flex-direction: column;
  }

  .article-item {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    align-items: start;
    gap: 2rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    animation: fadeUp 0.6s ease both;
  }

  .article-item:first-child { border-top: 1px solid var(--border); }
  .article-item:nth-child(1) { animation-delay: 0.3s; }
  .article-item:nth-child(2) { animation-delay: 0.38s; }
  .article-item:nth-child(3) { animation-delay: 0.46s; }
  .article-item:nth-child(4) { animation-delay: 0.54s; }
  .article-item:nth-child(n+5) { animation-delay: 0.6s; }

  .article-item:hover .article-title { color: var(--accent); }
  .article-item:hover .article-arrow { opacity: 1; transform: translateX(0); }

  .article-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.15rem;
  }

  .article-date {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--cream-dim);
    letter-spacing: 0.05em;
  }

  .article-tag {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-dim);
    border: 1px solid var(--accent-dim);
    padding: 0.15rem 0.5rem;
    width: fit-content;
    border-radius: 2px;
  }

  .article-title {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--cream);
    margin-bottom: 0.5rem;
    line-height: 1.35;
    transition: color 0.2s;
  }

  .article-excerpt {
    font-size: 0.9rem;
    color: var(--cream-dim);
    line-height: 1.65;
    max-width: 560px;
  }

  .article-arrow {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--accent);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.2s, transform 0.2s;
    padding-top: 0.2rem;
  }

  @media (max-width: 640px) {
    .hero, .section-divider, .articles { padding-left: 1.5rem; padding-right: 1.5rem; }
    .hero { padding-top: 3rem; padding-bottom: 3rem; }
    .article-item { grid-template-columns: 1fr; gap: 0.5rem; }
    .article-arrow { display: none; }
  }
</style>
